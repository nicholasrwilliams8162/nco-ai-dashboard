# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# App settings
PORT=3001
SESSION_SECRET=change_this_to_a_random_32_char_string

# Optional: set to 'true' to require login password
REQUIRE_AUTH=false
# Run: node -e "const b=require('bcrypt');b.hash('yourpassword',10).then(h=>console.log(h))" to generate
ADMIN_PASSWORD_HASH=
